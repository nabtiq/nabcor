{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nabcor.nabtiq.com/contracts/model-run.schema.json",
  "title": "Model Run record",
  "description": "One model/tool/image invocation with full accounting and attribution (INV-OBS-001). Aligned with the BC-001 observability requirements + session_id and attribution_confidence. Unmeasurable values are null, never silently estimated.",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "session_id",
    "project_id",
    "workspace_id",
    "brand_id",
    "workflow_id",
    "skill_id",
    "attribution_confidence",
    "provider",
    "model",
    "started_at",
    "input_tokens",
    "output_tokens",
    "cached_tokens",
    "cache_creation_tokens",
    "cost"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "run_id": {
      "type": "string"
    },
    "session_id": {
      "type": "string"
    },
    "project_id": {
      "type": "string"
    },
    "workspace_id": {
      "type": "string"
    },
    "brand_id": {
      "type": "string"
    },
    "workflow_id": {
      "type": "string"
    },
    "skill_id": {
      "type": "string"
    },
    "attribution_confidence": {
      "enum": [
        "confirmed",
        "likely",
        "unrelated",
        "unknown"
      ]
    },
    "artifact_ids_in": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifact_ids_out": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "context_manifest_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "provider": {
      "type": "string"
    },
    "model": {
      "type": "string"
    },
    "model_tier": {
      "enum": [
        0,
        1,
        2,
        3,
        4,
        null
      ]
    },
    "prompt_version": {
      "type": [
        "string",
        "null"
      ],
      "description": "hash of the skill prompt template"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "latency_ms": {
      "type": [
        "integer",
        "null"
      ]
    },
    "input_tokens": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "output_tokens": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "cached_tokens": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0,
      "description": "cache READS — first-class, never omitted"
    },
    "cache_creation_tokens": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0,
      "description": "cache WRITES — first-class, never omitted"
    },
    "reasoning_tokens": {
      "type": [
        "integer",
        "null"
      ],
      "description": "null where provider does not split — never estimated"
    },
    "cost": {
      "type": "object",
      "required": [
        "mode"
      ],
      "properties": {
        "mode": {
          "enum": [
            "api",
            "subscription",
            "free-tier"
          ]
        },
        "usd": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "description": "measured only when mode=api; otherwise null (never negative)"
        },
        "allocation": {
          "enum": [
            "measured",
            "none"
          ],
          "description": "subscription runs record allocation: none — never conflated (BC-001 rule)"
        }
      },
      "additionalProperties": false
    },
    "tool_calls": {
      "type": [
        "integer",
        "null"
      ]
    },
    "retry_count": {
      "type": [
        "integer",
        "null"
      ]
    },
    "failure_type": {
      "enum": [
        null,
        "rate_limit",
        "provider_error",
        "tool_error",
        "refusal",
        "outage",
        "loop_budget",
        "validation_failure"
      ]
    },
    "media": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "kind": {
          "type": "string"
        },
        "count": {
          "type": "integer"
        },
        "size": {
          "type": "string"
        },
        "quality": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "human_review": {
      "enum": [
        "none",
        "gated",
        "reviewed",
        null
      ]
    },
    "accepted": {
      "enum": [
        null,
        "accepted",
        "rejected",
        "superseded"
      ],
      "description": "set when known, not at call time"
    },
    "rejected_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "superseded_by": {
      "type": [
        "string",
        "null"
      ]
    },
    "provider_request_id": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[A-Za-z0-9_.-]{1,128}$",
      "description": "provider-reported request identifier (request-id header) where available, bounded to a safe shape so an untrusted header can never inject arbitrary content into a record; never a NABCor artifact ID"
    },
    "requested_model": {
      "type": [
        "string",
        "null"
      ],
      "description": "exact model ID sent to the provider (DEC-0019); null for offline runs"
    },
    "returned_model": {
      "type": [
        "string",
        "null"
      ],
      "description": "model ID the provider response reported; a mismatch with requested_model is a typed failure (threat T09)"
    },
    "attempt": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1,
      "description": "attempt number this record's outcome came from (at most max_attempts_per_request)"
    },
    "reserved_usd": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "description": "conservative pre-invocation budget reservation for the recorded attempt(s)"
    },
    "pricing_version": {
      "type": [
        "string",
        "null"
      ],
      "description": "the pinned price table used for reservation and settlement (provider-policy-candidate.pricing_version)"
    },
    "budget_remaining_usd": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "run": {
          "type": "number"
        },
        "day": {
          "type": "number"
        },
        "month": {
          "type": "number"
        }
      },
      "required": [
        "run",
        "day",
        "month"
      ],
      "additionalProperties": false,
      "description": "remaining USD budget after settlement, per ceiling scope"
    },
    "output_contract": {
      "type": [
        "string",
        "null"
      ],
      "description": "the NABCor contract the structured output was validated against"
    },
    "data_classification": {
      "enum": [
        "synthetic",
        null
      ],
      "description": "data class of every input this run carried; only synthetic is permitted on any provider path (DEC-0018)"
    },
    "retention_status": {
      "enum": [
        "STANDARD_UP_TO_30_DAYS",
        null
      ],
      "description": "provider retention posture in effect for this run (conservative official default; no ZDR claim)"
    },
    "live_authorization_ref": {
      "type": [
        "string",
        "null"
      ],
      "description": "reference to the consumed live-call authorization when live invocation is eventually approved; null in this phase (live invocation disabled)"
    }
  },
  "examples": [
    {
      "schema_version": "1.9.0",
      "run_id": "run_0042",
      "session_id": "sess_001",
      "project_id": "SLICE-001",
      "workspace_id": "ws_local_mba",
      "brand_id": "brand_example",
      "workflow_id": "slice-run-01",
      "skill_id": "validate-claims",
      "attribution_confidence": "confirmed",
      "artifact_ids_in": [
        "wspec_0001",
        "claim_001"
      ],
      "artifact_ids_out": [
        "eval_0001"
      ],
      "context_manifest_ref": "cm_0042",
      "provider": "anthropic",
      "model": "example-model-id",
      "model_tier": 2,
      "prompt_version": "sha256:abc123",
      "started_at": "2026-07-17T12:00:00Z",
      "latency_ms": 4200,
      "input_tokens": 1850,
      "output_tokens": 640,
      "cached_tokens": 42000,
      "cache_creation_tokens": 0,
      "reasoning_tokens": null,
      "cost": {
        "mode": "api",
        "usd": 0.09,
        "allocation": "measured"
      },
      "tool_calls": 3,
      "retry_count": 0,
      "failure_type": null,
      "media": null,
      "human_review": "none",
      "accepted": null,
      "rejected_reason": null,
      "superseded_by": null
    }
  ],
  "additionalProperties": false
}
