{
  "schema_version": "1.10.0",
  "policy_id": "hgp-nabcor-1",
  "policy_version": 3,
  "decision_ref": "DEC-0019",
  "signature_algorithm": "ed25519",
  "payload_type": "nabcor-human-gate-approval",
  "payload_version": "1.0.0",
  "canonicalization_algorithm": "approval-payload-sha256-1.0.0",
  "domain_separator": "nabcor-human-gate-approval-v1",
  "authority_registry_ref": "areg-nabcor",
  "authority_registry_version": 2,
  "independent_reviewer_named": false,
  "allowed_gates": [
    "fact-resolution-approval",
    "quarantine-release",
    "client-facing-publishing",
    "blocking-evaluation-gate-change",
    "real-client-data-provider-approval",
    "provider-enablement-approval",
    "live-provider-call-approval"
