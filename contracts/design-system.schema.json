{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nabcor.nabtiq.com/contracts/design-system.schema.json",
  "title": "Design System",
  "description": "Deterministic compilation of a Visual World into per-theme semantic token tables. All declared themes carry values from day one; future channel adapters map them to implementation-specific tokens.",
  "allOf": [
    {
      "$ref": "artifact-envelope.schema.json#/definitions/envelope"
    },
    {
      "type": "object",
      "required": [
        "brand_ref",
        "visual_world_ref",
        "themes"
      ],
      "properties": {
        "brand_ref": {
          "type": "string"
        },
        "visual_world_ref": {
          "type": "string"
        },
        "themes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "theme_id",
              "tokens"
            ],
            "properties": {
              "theme_id": {
                "type": "string"
              },
              "tokens": {
                "type": "object",
                "description": "semantic token → value map (raw color ramp plus semantic alias layers)",
                "minProperties": 1
              },
              "contrast_checked": {
                "type": "boolean",
                "description": "WCAG AA pass recorded per theme"
              }
            },
            "additionalProperties": false
          }
        },
        "spacing_scale": {
          "type": "array",
          "items": {
            "type": "number"
          }
        },
        "radii": {
          "type": "object"
        },
        "compiled_outputs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "paths of generated tokens.css etc. (Phase 2+)"
        }
      }
    }
  ],
  "examples": [
    {
      "schema_version": "1.10.0",
      "artifact_id": "ds_0001",
      "brand_ref": "brand_example",
      "created_at": "2026-07-17T12:00:00Z",
      "creator_type": "deterministic",
      "lifecycle_status": "generated",
      "visual_world_ref": "vw_0001",
      "themes": [
        {
          "theme_id": "light",
          "tokens": {
            "--color-brand-500": "#1a2b3c",
            "--color-canvas": "#fafafa"
          },
          "contrast_checked": false
        }
      ]
    }
  ],
  "propertyNames": {
    "enum": [
      "approvals",
      "artifact_id",
      "brand_ref",
      "compiled_outputs",
      "created_at",
      "creator_type",
      "derived_from_runs",
      "lifecycle_status",
      "project_ref",
      "provisional",
      "radii",
      "schema_version",
      "spacing_scale",
      "superseded_by",
      "supersedes",
      "themes",
      "validation_status",
      "visual_world_ref"
    ]
  }
}
