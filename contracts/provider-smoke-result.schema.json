{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nabcor.nabtiq.com/contracts/provider-smoke-result.schema.json",
  "title": "Provider smoke result",
  "description": "The sanitized, immutable record of the ONE real provider smoke request (DEC-0020). It carries identifiers, token counts, USD accounting, and validation outcomes ONLY — never a prompt, response body, header, or credential. It binds the exact signed live-provider-call-request and its single-use consumption receipt, so a result can never be fabricated independently of a consumed authorization. status is 'succeeded' only when the response passed every local validation; a failed or ambiguous outcome records status 'failed' with a typed, redacted failure_reason and leaves the operational-state smoke flag false.",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_id",
    "workspace",
    "brand_ref",
    "created_at",
    "live_call_request_ref",
    "live_call_request_digest",
    "live_call_receipt_ref",
    "provider",
    "requested_model",
    "returned_model",
    "provider_request_id",
    "attempt",
    "retry_count",
    "status",
    "failure_reason",
    "input_tokens",
    "output_tokens",
    "cached_tokens",
    "cache_creation_tokens",
    "reserved_usd",
    "settled_usd",
    "pricing_version",
    "retention_status",
    "output_contract",
    "output_artifact_digest",
    "started_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "artifact_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$" },
    "workspace": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$" },
    "brand_ref": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$" },
    "created_at": { "type": "string", "format": "date-time" },
    "live_call_request_ref": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$" },
    "live_call_request_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "live_call_receipt_ref": {
      "type": ["string", "null"],
      "pattern": "^r[0-9a-f]{64}$",
      "description": "the single-use authorization consumption receipt; non-null once the authorization was consumed exactly once. A succeeded result always carries it; a failure that occurred BEFORE consumption (request/authorization/budget refusal) carries null (semantic layer)"
    },
    "provider": { "const": "anthropic" },
    "requested_model": { "const": "claude-haiku-4-5-20251001" },
    "returned_model": {
      "type": ["string", "null"],
      "pattern": "^[A-Za-z0-9._-]{1,128}$",
      "description": "model the response reported (bounded); on success must equal requested_model (semantic layer)"
    },
    "provider_request_id": {
      "type": ["string", "null"],
      "pattern": "^[A-Za-z0-9_.-]{1,128}$",
      "description": "sanitized provider request-id header; bounded so an untrusted header cannot inject content"
    },
    "attempt": { "const": 1 },
    "retry_count": { "const": 0 },
    "status": { "enum": ["succeeded", "failed"] },
    "failure_reason": {
      "type": ["string", "null"],
      "maxLength": 200,
      "description": "typed, redacted failure classification when status is failed; null on success (semantic layer)"
    },
    "input_tokens": { "type": ["integer", "null"], "minimum": 0 },
    "output_tokens": { "type": ["integer", "null"], "minimum": 0 },
    "cached_tokens": { "const": 0 },
    "cache_creation_tokens": { "const": 0 },
    "reserved_usd": { "type": "number", "minimum": 0, "maximum": 0.25 },
    "settled_usd": { "type": "number", "minimum": 0, "maximum": 0.25 },
    "pricing_version": { "const": "anthropic-official-2026-07-19-post-intro" },
    "retention_status": { "const": "STANDARD_UP_TO_30_DAYS" },
    "output_contract": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$" },
    "output_artifact_digest": {
      "type": ["string", "null"],
      "pattern": "^sha256:[0-9a-f]{64}$",
      "description": "content digest of the validated structured-output artifact on success; null on failure"
    },
    "started_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false,
  "examples": [
    {
      "schema_version": "1.10.0",
      "artifact_id": "psr-example-0001",
      "workspace": "ws_governance",
      "brand_ref": "brand_nabcor",
      "created_at": "2026-07-20T00:05:00Z",
      "live_call_request_ref": "lpcr-example-0001",
      "live_call_request_digest": "sha256:dddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddd",
      "live_call_receipt_ref": "raaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
      "provider": "anthropic",
      "requested_model": "claude-haiku-4-5-20251001",
      "returned_model": "claude-haiku-4-5-20251001",
      "provider_request_id": "req_smoke_synthetic_0001",
      "attempt": 1,
      "retry_count": 0,
      "status": "succeeded",
      "failure_reason": null,
      "input_tokens": 40,
      "output_tokens": 12,
      "cached_tokens": 0,
      "cache_creation_tokens": 0,
      "reserved_usd": 0.01,
      "settled_usd": 0.01,
      "pricing_version": "anthropic-official-2026-07-19-post-intro",
      "retention_status": "STANDARD_UP_TO_30_DAYS",
      "output_contract": "provider-smoke-echo",
      "output_artifact_digest": "sha256:eeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeee",
      "started_at": "2026-07-20T00:05:00Z"
    }
  ]
}
