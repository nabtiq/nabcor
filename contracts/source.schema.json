{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nabcor.nabtiq.com/contracts/source.schema.json",
  "title": "Source",
  "description": "One client-provided or acquired input with classification, technical facts, and rights (DOMAIN_MODEL §2; INV-DATA-002; INV-SEC-002; BC-001 F04 fields).",
  "allOf": [
    {
      "$ref": "artifact-envelope.schema.json#/definitions/envelope"
    },
    {
      "type": "object",
      "required": [
        "kind",
        "origin",
        "rights",
        "filename_or_locator",
        "capture"
      ],
      "allOf": [
        {
          "$comment": "INV-FACT-003 / DEC-0006: documentary status is never inferred from absence — visual kinds must state their classification explicitly, where null means explicitly unresolved.",
          "if": {
            "properties": {
              "kind": {
                "enum": [
                  "image",
                  "logo"
                ]
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "required": [
              "visual_classification"
            ]
          }
        }
      ],
      "properties": {
        "kind": {
          "enum": [
            "document",
            "image",
            "logo",
            "reference",
            "url",
            "prompt",
            "brief",
            "video",
            "other"
          ]
        },
        "origin": {
          "enum": [
            "client",
            "operator",
            "generated",
            "licensed",
            "public_web"
          ]
        },
        "filename_or_locator": {
          "type": "string"
        },
        "rights": {
          "$ref": "artifact-envelope.schema.json#/definitions/rights"
        },
        "capture": {
          "type": "object",
          "description": "Auditable capture state (DEC-0006): captured content is content-addressed and immutable; descriptors without bytes and unfetched URLs say so honestly. Captured content is never stored inline in the artifact.",
          "required": [
            "status"
          ],
          "properties": {
            "status": {
              "enum": [
                "captured",
                "descriptor-only",
                "external-unfetched"
              ]
            },
            "content_ref": {
              "type": "string",
              "pattern": "^sha256:[0-9a-f]{64}$",
              "description": "content-store reference for the captured bytes"
            },
            "sha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            "bytes": {
              "type": "integer",
              "minimum": 0
            },
            "media_type": {
              "type": [
                "string",
                "null"
              ]
            },
            "safety": {
              "enum": [
                "clear",
                "quarantined"
              ],
              "description": "quarantined content lives in an isolated namespace; normal retrieval cannot return it (INV-SEC-002)"
            }
          },
          "additionalProperties": false,
          "allOf": [
            {
              "if": {
                "properties": {
                  "status": {
                    "const": "captured"
                  }
                }
              },
              "then": {
                "required": [
                  "status",
                  "content_ref",
                  "sha256",
                  "bytes",
                  "safety"
                ]
              }
            }
          ]
        },
        "asset_facts": {
          "type": "object",
          "description": "intake-mandatory for image/logo kinds (BC-001 F04)",
          "properties": {
            "has_alpha": {
              "type": "boolean"
            },
            "vector_available": {
              "type": "boolean"
            },
            "source_resolution": {
              "type": "string"
            },
            "aspect_ratio": {
              "type": "string"
            },
            "variants": {
              "type": "object",
              "properties": {
                "dark": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "light": {
                  "type": [
                    "string",
                    "null"
                  ]
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "visual_classification": {
          "enum": [
            "documentary",
            "illustrative",
            "generated",
            "conceptual",
            null
          ],
          "description": "PROVENANCE §11; required for visual kinds"
        },
        "carries_own_brand_content": {
          "type": "boolean",
          "description": "reference materials carrying the client's own brand are ALSO mined (BC-001 FAIL-01 fix)"
        },
        "injection_flag": {
          "type": "boolean",
          "description": "instruction-like embedded text detected (INV-SEC-002)"
        },
        "injection_note": {
          "type": "string"
        },
        "transformation_history": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "step"
            ],
            "properties": {
              "step": {
                "type": "string"
              },
              "tool_or_model": {
                "type": "string"
              },
              "run_ref": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        }
      }
    }
  ],
  "examples": [
    {
      "schema_version": "1.8.0",
      "artifact_id": "src_0001",
      "brand_ref": "brand_josour",
      "created_at": "2026-07-17T12:00:00Z",
      "creator_type": "deterministic",
      "lifecycle_status": "accepted",
      "kind": "document",
      "origin": "client",
      "filename_or_locator": "company-profile.pdf",
      "rights": {
        "commercial_use": "allowed",
        "advertising_use": "unknown",
        "benchmark_use": "forbidden",
        "training_use": "forbidden"
      },
      "capture": {
        "status": "descriptor-only"
      },
      "injection_flag": false
    },
    {
      "schema_version": "1.8.0",
      "artifact_id": "src_0002",
      "brand_ref": "brand_josour",
      "created_at": "2026-07-17T12:00:00Z",
      "creator_type": "deterministic",
      "lifecycle_status": "generated",
      "kind": "prompt",
      "origin": "client",
      "filename_or_locator": "prompt-0001",
      "rights": {
        "commercial_use": "unknown",
        "advertising_use": "unknown",
        "benchmark_use": "forbidden",
        "training_use": "forbidden"
      },
      "capture": {
        "status": "captured",
        "content_ref": "sha256:9f86d081884c7d659a2feaa0c55ad015a3bf4f1b2b0b822cd15d6c15b0f00a08",
        "sha256": "9f86d081884c7d659a2feaa0c55ad015a3bf4f1b2b0b822cd15d6c15b0f00a08",
        "bytes": 4,
        "media_type": "text/plain",
        "safety": "clear"
      },
      "injection_flag": false
    }
  ],
  "propertyNames": {
    "enum": [
      "approvals",
      "artifact_id",
      "asset_facts",
      "brand_ref",
      "capture",
      "carries_own_brand_content",
      "created_at",
      "creator_type",
      "derived_from_runs",
      "filename_or_locator",
      "injection_flag",
      "injection_note",
      "kind",
      "lifecycle_status",
      "origin",
      "project_ref",
      "provisional",
      "rights",
      "schema_version",
      "superseded_by",
      "supersedes",
      "transformation_history",
      "validation_status",
      "visual_classification"
    ]
  }
}
