{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nabcor.nabtiq.com/contracts/claim.schema.json",
  "title": "Claim",
  "description": "One statement with classification, provenance, confidence, verification state (PROVENANCE_AND_CONFIDENCE.md; INV-FACT-001/002).",
  "allOf": [
    {
      "$ref": "artifact-envelope.schema.json#/definitions/envelope"
    },
    {
      "type": "object",
      "required": [
        "statement",
        "classification",
        "source_type",
        "confidence",
        "verification_status"
      ],
      "properties": {
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "classification": {
          "enum": [
            "factual",
            "inference",
            "hypothesis",
            "preference"
          ]
        },
        "source_type": {
          "enum": [
            "uploaded_document",
            "uploaded_image",
            "client_statement",
            "operator_input",
            "public_web",
            "reference_material",
            "model_inference",
            "model_generation"
          ]
        },
        "source_ref": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^source:[A-Za-z0-9][A-Za-z0-9._-]{0,127}(#(codepoints=[0-9]{1,9}-[0-9]{1,9}|page=[1-9][0-9]{0,8}))?$",
          "description": "canonical source reference tied to a source artifact ID (DEC-0006/DEC-0007), e.g. source:src_0001#page=3 or source:src_0002#codepoints=57-88 — codepoints are zero-based half-open Unicode code-point offsets, never UTF-16 units or bytes; REQUIRED for factual (enforced below); filename-based locators and the retired #chars= form are rejected"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "confidence_basis": {
          "type": "string",
          "description": "a bare number is invalid (PROVENANCE §4)"
        },
        "verification_status": {
          "enum": [
            "verified",
            "unconfirmed",
            "contradicted",
            "expired",
            "rejected"
          ]
        },
        "verified_by": {
          "type": [
            "string",
            "null"
          ],
          "description": "user id when human-confirmed"
        },
        "valid_from": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "valid_until": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "ref",
              "direction"
            ],
            "properties": {
              "ref": {
                "type": "string"
              },
              "direction": {
                "enum": [
                  "supports",
                  "contradicts"
                ]
              },
              "note": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "resolution_decision_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "fact_key": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$",
          "description": "stable machine-readable fact-slot key (DEC-0011), e.g. identity.primary_name, market.default_locale, organization.founded_year; present only together with normalized_value"
        },
        "normalized_value": {
          "type": [
            "string",
            "number",
            "boolean"
          ],
          "description": "explicit normalized scalar for deterministic comparison (DEC-0011): scalar only in this phase (arrays, objects, and null are rejected); comparison is exact and type-sensitive — string \"1\" differs from number 1, no case folding, no Unicode normalization, no unit conversion; a normalized value never upgrades verification status"
        },
        "normalization_basis": {
          "type": "string",
          "minLength": 1,
          "description": "how normalized_value was derived from the statement — any normalization happens upstream and is disclosed here, never hidden in comparison (DEC-0011)"
        }
      },
      "dependencies": {
        "fact_key": [
          "normalized_value",
          "normalization_basis"
        ],
        "normalized_value": [
          "fact_key",
          "normalization_basis"
        ],
        "normalization_basis": [
          "fact_key",
          "normalized_value"
        ]
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "classification": {
                "const": "factual"
              }
            }
          },
          "then": {
            "required": [
              "source_ref",
              "confidence_basis"
            ],
            "properties": {
              "source_ref": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        {
          "$comment": "DEC-0011: structured fact metadata is permitted only for classifications that can state something about the brand or world (factual, inference); preferences and hypotheses must not silently participate as facts.",
          "if": {
            "properties": {
              "classification": {
                "enum": [
                  "hypothesis",
                  "preference"
                ]
              }
            }
          },
          "then": {
            "not": {
              "required": [
                "fact_key"
              ]
            }
          }
        }
      ]
    }
  ],
  "examples": [
    {
      "schema_version": "1.7.0",
      "artifact_id": "claim_001",
      "brand_ref": "brand_example",
      "created_at": "2026-07-17T12:00:00Z",
      "creator_type": "agent",
      "lifecycle_status": "accepted",
      "statement": "The company operates in Dubai",
      "classification": "factual",
      "source_type": "uploaded_document",
      "source_ref": "source:src_0001#page=3",
      "confidence": 0.98,
      "confidence_basis": "explicit statement in client's own profile document",
      "verification_status": "verified"
    },
    {
      "schema_version": "1.7.0",
      "artifact_id": "claim_002",
      "brand_ref": "brand_example",
      "created_at": "2026-07-17T12:00:00Z",
      "creator_type": "agent",
      "lifecycle_status": "generated",
      "statement": "The likely audience includes legal firms",
      "classification": "inference",
      "source_type": "model_inference",
      "source_ref": null,
      "confidence": 0.62,
      "confidence_basis": "category norm for forensic consultancies; no client evidence",
      "verification_status": "unconfirmed"
    },
    {
      "schema_version": "1.7.0",
      "artifact_id": "claim_003",
      "brand_ref": "brand_example",
      "created_at": "2026-07-17T12:00:00Z",
      "creator_type": "agent",
      "lifecycle_status": "accepted",
      "statement": "The company's primary brand name is Veritas Forensics",
      "classification": "factual",
      "source_type": "uploaded_document",
      "source_ref": "source:src_0001#page=1",
      "confidence": 0.97,
      "confidence_basis": "name printed on the client's own profile document cover",
      "verification_status": "verified",
      "fact_key": "identity.primary_name",
      "normalized_value": "Veritas Forensics",
      "normalization_basis": "verbatim name as printed; no case folding, no Unicode normalization"
    }
  ],
  "propertyNames": {
    "enum": [
      "approvals",
      "artifact_id",
      "brand_ref",
      "classification",
      "confidence",
      "confidence_basis",
      "created_at",
      "creator_type",
      "derived_from_runs",
      "evidence",
      "fact_key",
      "lifecycle_status",
      "normalization_basis",
      "normalized_value",
      "project_ref",
      "provisional",
      "resolution_decision_ref",
      "schema_version",
      "source_ref",
      "source_type",
      "statement",
      "superseded_by",
      "supersedes",
      "valid_from",
      "valid_until",
      "validation_status",
      "verification_status",
      "verified_by"
    ]
  }
}
