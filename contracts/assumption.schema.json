{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nabcor.nabtiq.com/contracts/assumption.schema.json",
  "title": "Assumption",
  "description": "A working belief with risk class, owner, and revisit condition (DOMAIN_MODEL §2; Master Prompt §14).",
  "allOf": [
    {
      "$ref": "artifact-envelope.schema.json#/definitions/envelope"
    },
    {
      "type": "object",
      "required": [
        "statement",
        "risk",
        "status",
        "revisit_trigger"
      ],
      "properties": {
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "risk": {
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "status": {
          "enum": [
            "open",
            "confirmed",
            "retired",
            "violated"
          ]
        },
        "owner": {
          "type": [
            "string",
            "null"
          ]
        },
        "revisit_trigger": {
          "type": "string",
          "description": "'never' is not a trigger"
        },
        "expires_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "affects": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "artifact ids depending on this assumption"
        }
      }
    }
  ],
  "examples": [
    {
      "schema_version": "1.6.0",
      "artifact_id": "asm_brand_0001",
      "brand_ref": "brand_example",
      "created_at": "2026-07-17T12:00:00Z",
      "creator_type": "agent",
      "lifecycle_status": "accepted",
      "statement": "EN-first with AR optional is acceptable for this Dubai market brand",
      "risk": "medium",
      "status": "open",
      "owner": "operator",
      "revisit_trigger": "client confirms language priorities at facts gate",
      "affects": [
        "brief_0001"
      ]
    }
  ],
  "propertyNames": {
    "enum": [
      "affects",
      "approvals",
      "artifact_id",
      "brand_ref",
      "created_at",
      "creator_type",
      "derived_from_runs",
      "expires_at",
      "lifecycle_status",
      "owner",
      "project_ref",
      "provisional",
      "revisit_trigger",
      "risk",
      "schema_version",
      "statement",
      "status",
      "superseded_by",
      "supersedes",
      "validation_status"
    ]
  }
}
