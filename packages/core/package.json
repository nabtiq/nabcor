{
  "name": "@nabcor/core",
  "version": "0.1.0",
  "description": "nabcor core: content schema, theme contract, shared components, SEO, security, contact pipeline, deploy scaffolding.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
    "./components": { "types": "./dist/components/index.d.ts", "default": "./dist/components/index.js" },
    "./server": { "types": "./dist/server/index.d.ts", "default": "./dist/server/index.js" },
    "./security": { "types": "./dist/security/headers.d.ts", "default": "./dist/security/headers.js" },
    "./package.json": "./package.json"
  },
  "files": ["dist", "deploy"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "peerDependencies": {
    "next": "^15.5.0",
    "next-intl": "^3.26.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "next-intl": { "optional": true }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "next": "^15.5.19",
    "react": "^19.0.0"
  }
}
